# ── LLM API Keys ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Agent Backend ─────────────────────────────────────────────
AURA_AGENT_BACKEND=ollama

# ── Ollama Configuration ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Camera ────────────────────────────────────────────────────
CAMERA_DEVICE_ID=0

# ── Debug ─────────────────────────────────────────────────────
AURA_DEBUG=false
AURA_LOG_LEVEL=INFO

# ── Hardware Serial ───────────────────────────────────────────
SERIAL_PORT=/dev/ttyUSB0
SERIAL_ENABLED=false